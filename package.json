{
  "name": "ventrapos",
  "version": "0.2.0",
  "description": "Cloud POS for supermarkets, pharmacies, restaurants, and growing retailers.",
  "author": "VentraPOS",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "electron:dev": "concurrently --kill-others \"pnpm dev\" \"wait-on http://localhost:3000 && electron .\"",
    "icons:prepare": "node electron/build/prepare-icons.js",
    "electron:build": "pnpm icons:prepare && pnpm build && electron-builder --config electron-builder.json --win"
  },
