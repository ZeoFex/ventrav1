{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.ventrapos.desktop",
  "productName": "VentraPOS",
  "directories": {
    "output": "release"
  },
  "afterPack": "build-hooks/afterPack.js",
  "files": [
    "electron/**/*",
    "public/**/*"
  ],
  "extraResources": [
    {
      "from": ".next/standalone",
      "to": "app/.next/standalone",
      "filter": [
        "**/*",
        ".next/standalone/node_modules/**/*"
      ]
    },
    {
      "from": ".next/static",
      "to": "app/.next/standalone/.next/static",
      "filter": ["**/*"]
    },
    {
      "from": "public",
      "to": "app/.next/standalone/public",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "electron/build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "electron/build/icon.ico",
    "uninstallerIcon": "electron/build/icon.ico"
  }
}
